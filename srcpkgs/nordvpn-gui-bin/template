# Template file for 'nordvpn-gui-bin'
pkgname=nordvpn-gui-bin
version=4.3.1
revision=1
archs="x86_64 aarch64"
build_style=fetch
short_desc="NordVPN GUI tool for Linux"
depends="nordvpn-bin"
makedepends="tar"
maintainer="Orphaned <orphan@voidlinux.org>"
license="custom"
homepage="https://nordvpn.com"
nopie=true
noshlibprovides=true
system_groups="nordvpn"
repository=nonfree

case "$XBPS_TARGET_MACHINE" in
	x86_64)
		_deb="nordvpn-gui_${version//v/-}_amd64.deb"
		distfiles="https://repo.nordvpn.com/deb/nordvpn/debian/pool/main/n/nordvpn-gui/nordvpn-gui_${version//v/-}_amd64.deb"
		checksum=24faec515e1caae6e15f1512181c96433ec74187ad998712fbc67107dd543be4
		;;
	aarch64)
		_deb="nordvpn_${version//v/-}_arm64.deb"
		distfiles="https://repo.nordvpn.com/deb/nordvpn/debian/pool/main/n/nordvpn-gui/nordvpn-gui_${version//v/-}_arm64.deb"
		checksum=91c3258b2132e2e920e2bc31a5da73625a01cb394d2b151b4b70b3e65aee1f2a
		;;
esac

do_install() {

	ar p "${_deb}" data.tar.gz > data.tar.gz
	tar -C "${DESTDIR}" -xvf data.tar.gz
	mkdir -p  "${DESTDIR}/usr/bin"
	ln -s /opt/nordvpn-gui/nordvpn-gui "${DESTDIR}/usr/bin/nordvpn-gui"

}
